# Weather Analytics Pipeline — Environment Variables
# Copy this file to .env and fill in your values

# ── Database ──────────────────────────────────────────────────
DB_TYPE=duckdb
DB_PATH=weather_analytics.duckdb

# Uncomment and fill for PostgreSQL
# DB_TYPE=postgresql
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=weather_db
# DB_USER=postgres
# DB_PASSWORD=yourpassword

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
